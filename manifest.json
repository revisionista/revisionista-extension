{
  "manifest_version": 2,
  "name": "Revisionista",
  "description": "Revisionista Browser Extension",
  "version": "1.1.1",
  "permissions": [
    "tabs",
    "activeTab",
    "contextMenus",
    "<all_urls>"
  ],
  "browser_specific_settings": {
    "gecko": {
        "id": "{08023c51-ff2b-4a56-b1df-ffa84d41d7b2}",
        "data_collection_permissions": {
          "required": [
             "locationInfo"
          ]
         }
      }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "19": "icons/icon19.png",
      "32": "icons/icon32.png",
      "38": "icons/icon38.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "scripts": [
      "vendor/browser-polyfill.js",
      "vendor/executeScript-helper.js",
      "vendor/fetch-browserified.js",
      "vendor/fetch-retry-browserified.js",
      "vendor/tldjs-browserified.js",
      "vendor/Readability.js",
      "background_scripts/background.js"
    ]
  },
  "content_scripts": [{
    "matches": [
      "<all_urls>"
    ],
    "js": [
      "vendor/browser-polyfill.js",
      "vendor/Readability-readerable.js",
      "content_scripts/content.js"
    ]
  }],
  "web_accessible_resources": [
    "et-book/*"
  ]
}
